{
  "version": 3,
  "pages404": true,
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [],
    "fallback": []
  },
  "dynamicRoutes": [
    {
      "page": "/countries/[name]",
      "regex": "^/countries/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPname": "nxtPname"
      },
      "namedRegex": "^/countries/(?<nxtPname>[^/]+?)(?:/)?$"
    }
  ],
  "staticRoutes": [
    {
      "page": "/",
      "regex": "^/(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/(?:/)?$"
    },
    {
      "page": "/_not-found",
      "regex": "^/_not\\-found(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_not\\-found(?:/)?$"
    },
    {
      "page": "/about-1",
      "regex": "^/about\\-1(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/about\\-1(?:/)?$"
    },
    {
      "page": "/blog",
      "regex": "^/blog(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/blog(?:/)?$"
    },
    {
      "page": "/blog-details",
      "regex": "^/blog\\-details(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/blog\\-details(?:/)?$"
    },
    {
      "page": "/contact",
      "regex": "^/contact(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/contact(?:/)?$"
    },
    {
      "page": "/countries",
      "regex": "^/countries(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/countries(?:/)?$"
    },
    {
      "page": "/course-details",
      "regex": "^/course\\-details(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/course\\-details(?:/)?$"
    },
    {
      "page": "/faq",
      "regex": "^/faq(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/faq(?:/)?$"
    },
    {
      "page": "/icon.png",
      "regex": "^/icon\\.png(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/icon\\.png(?:/)?$"
    },
    {
      "page": "/index-2",
      "regex": "^/index\\-2(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/index\\-2(?:/)?$"
    },
    {
      "page": "/index-3",
      "regex": "^/index\\-3(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/index\\-3(?:/)?$"
    },
    {
      "page": "/index-4",
      "regex": "^/index\\-4(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/index\\-4(?:/)?$"
    },
    {
      "page": "/instructor",
      "regex": "^/instructor(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/instructor(?:/)?$"
    },
    {
      "page": "/instructor-details",
      "regex": "^/instructor\\-details(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/instructor\\-details(?:/)?$"
    },
    {
      "page": "/services",
      "regex": "^/services(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/services(?:/)?$"
    }
  ],
  "dataRoutes": [],
  "rsc": {
    "header": "rsc",
    "varyHeader": "rsc, next-router-state-tree, next-router-prefetch, next-router-segment-prefetch",
    "prefetchHeader": "next-router-prefetch",
    "didPostponeHeader": "x-nextjs-postponed",
    "contentTypeHeader": "text/x-component",
    "suffix": ".rsc",
    "prefetchSuffix": ".prefetch.rsc",
    "prefetchSegmentHeader": "next-router-segment-prefetch",
    "prefetchSegmentSuffix": ".segment.rsc",
    "prefetchSegmentDirSuffix": ".segments"
  },
  "rewriteHeaders": {
    "pathHeader": "x-nextjs-rewritten-path",
    "queryHeader": "x-nextjs-rewritten-query"
  }
}